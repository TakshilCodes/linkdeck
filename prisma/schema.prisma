generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  username       String?       @unique
  displayName    String?
  profileImgUrl  String?
  bio            String?
  hashedPassword String?
  defaultThemeId String?
  defaultTheme   DefaultTheme? @relation(fields: [defaultThemeId], references: [id])

  onboardingStep OnboardingStep     @default(USERNAME)
  onboardingDone Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  authProvider   authProvider
  collections    Collection[]
  links          Link[]
  icons          SocialIcon[]
  customization  UserCustomization?
  boardItems BoardItem[]
}

enum OnboardingStep {
  USERNAME
  THEME
  PLATFORMS
  LINKS
  PROFILE
  DONE
}

model Link {
  id                String      @id @default(uuid())
  userId            String
  collectionId      String?
  name              String
  url               String
  isVisible         Boolean     @default(true)
  isLocked          Boolean     @default(false)
  isSensitive       Boolean     @default(false)
  clickCount        Int         @default(0)
  position          Int
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  boardItem  BoardItem?
  collection        Collection? @relation(fields: [collectionId], references: [id])
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, position])
}

model Collection {
  id        String   @id @default(uuid())
  userId    String
  name      String
  isVisible Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  boardItem  BoardItem?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  links     Link[]

  @@index([userId, position])
}

model BoardItem {
  id           String        @id @default(uuid())
  userId       String
  type         BoardItemType
  position     Int

  linkId       String?       @unique
  collectionId String?       @unique

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  link         Link?         @relation(fields: [linkId], references: [id], onDelete: Cascade)
  collection   Collection?   @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([userId, position])
}

enum BoardItemType {
  LINK
  COLLECTION
}

model SocialIcon {
  id        String   @id @default(uuid())
  userId    String
  type      IconType
  value     String
  label     String?
  isVisible Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, position])
}

model DefaultTheme {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  previewImgUrl     String?
  wallpaperStyle    WallpaperStyle
  backgroundColor   String
  backgroundColor2  String?
  gradientDirection GradientDirection?
  patternStyle      PatternStyle?
  blurStrength      BlurStrength?
  fontFamily        FontFamily
  buttonStyle       ButtonStyle
  buttonRadius      ButtonRadius
  buttonShadow      ButtonShadow
  buttonColor       String
  buttonTextColor   String
  shadowColor       String?
  patternColor      String?
  outlineColor      String?
  titleFontSize     titleFontSize?
  titleColor        String
  titleFontWeight   titleFontWeight?
  profileFontSize   profileFontSize?
  profileColor      String
  isDefault         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
}

model UserCustomization {
  id                String             @id @default(uuid())
  userId            String             @unique
  wallpaperStyle    WallpaperStyle?
  backgroundColor   String?
  backgroundColor2  String?
  gradientDirection GradientDirection?
  patternStyle      PatternStyle?
  blurStrength      BlurStrength?
  fontFamily        FontFamily?
  buttonStyle       ButtonStyle?
  buttonRadius      ButtonRadius?
  buttonShadow      ButtonShadow?
  buttonColor       String?
  buttonTextColor   String?
  shadowColor       String?
  patternColor      String?
  outlineColor      String?
  titleFontSize     titleFontSize?
  titleColor        String?
  titleFontWeight   titleFontWeight?
  profileFontSize   profileFontSize?
  profileColor      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum titleFontSize {
  SMALL
  MEDIUM
  LARGE
}

enum profileFontSize {
  SMALL
  MEDIUM
  LARGE
}

enum titleFontWeight {
  NONE
  SOFT
  MEDIUM
  STRONG
}

enum BlurStrength {
  NONE
  SOFT
  MEDIUM
  STRONG
}

enum FontFamily {
  INTER
  POPPINS
  MONTSERRAT
  ROBOTO
  PLAYFAIR
  OUTFIT
}

enum authProvider {
  GOOGLE
  GITHUB
  CREDENTIALS
}

enum IconType {
  INSTAGRAM
  X
  LINKEDIN
  FACEBOOK
  YOUTUBE
  GITHUB
  PERSONAL_WEBSITE
  PATREON
  KICK
  DISCORD
  PINTEREST
  TWITCH
  TELEGRAM
  THREADS
  SNAPCHAT
}

enum WallpaperStyle {
  FILL
  GRADIENT
  BLUR
  PATTERN
}

enum GradientDirection {
  LINEAR_UP
  LINEAR_DOWN
  RADIAL
}

enum PatternStyle {
  GRID
  MORPH
  ORGANIC
  MATRIX
}

enum ButtonStyle {
  SOLID
  GLASS
  OUTLINE
}

enum ButtonRadius {
  SQUARE
  ROUND
  ROUNDER
  FULL
}

enum ButtonShadow {
  NONE
  SOFT
  STRONG
  HARD
}
