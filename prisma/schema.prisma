generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  DisplayName  String?
  email        String   @unique
  Hashpassword String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}