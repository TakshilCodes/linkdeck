generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  username       String?            @unique
  displayName    String?
  profileImgUrl  String?
  bio            String?
  hashedPassword String?
  themeId        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  authProvider   authProvider
  collections    Collection[]
  links          Link[]
  icons          SocialIcon[]
  theme          DefaultTheme?      @relation(fields: [themeId], references: [id])
  customization  UserCustomization?
}

model Link {
  id                String      @id @default(uuid())
  userId            String
  collectionId      String?
  name              String
  url               String
  isVisible         Boolean     @default(true)
  isLocked          Boolean     @default(false)
  lockToSubscribers Boolean     @default(false)
  isSensitive       Boolean     @default(false)
  clickCount        Int         @default(0)
  position          Int
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  collection        Collection? @relation(fields: [collectionId], references: [id])
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Collection {
  id        String   @id @default(uuid())
  userId    String
  name      String
  isVisible Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  links     Link[]
}

model SocialIcon {
  id        String   @id @default(uuid())
  userId    String
  type      IconType
  url       String
  label     String?
  isVisible Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DefaultTheme {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  previewImgUrl     String?
  wallpaperStyle    WallpaperStyle
  backgroundColor   String?
  backgroundColor2  String?
  gradientDirection GradientDirection?
  patternStyle      PatternStyle?
  blurStrength      String?
  fontFamily        String?
  buttonStyle       ButtonStyle
  buttonRadius      ButtonRadius
  buttonShadow      ButtonShadow
  buttonColor       String?
  buttonTextColor   String?
  shadowColor       String?
  patternColor      String?
  outlineColor      String?
  titleFontSize     String?
  titleColor        String?
  titleFontWeight   String?
  profileFontSize   String?
  profileColor      String?
  isDefault         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
}

model UserCustomization {
  id                String             @id @default(uuid())
  userId            String             @unique
  wallpaperStyle    WallpaperStyle?
  backgroundColor   String?
  backgroundColor2  String?
  gradientDirection GradientDirection?
  patternStyle      PatternStyle?
  blurStrength      String?
  fontFamily        String?
  buttonStyle       ButtonStyle?
  buttonRadius      ButtonRadius?
  buttonShadow      ButtonShadow?
  buttonColor       String?
  buttonTextColor   String?
  shadowColor       String?
  patternColor      String?
  outlineColor      String?
  titleFontSize     String?
  titleColor        String?
  titleFontWeight   String?
  profileFontSize   String?
  profileColor      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum authProvider {
  GOOGLE
  GITHUB
  CREDENTIALS
}

enum IconType {
  INSTAGRAM
  X
  LINKEDIN
  FACEBOOK
  YOUTUBE
  GITHUB
  PERSONAL_WEBSITE
  PATREON
  KICK
  DISCORD
  PINTEREST
  TWITCH
  TELEGRAM
  THREADS
  SNAPCHAT
}

enum WallpaperStyle {
  FILL
  GRADIENT
  BLUR
  PATTERN
}

enum GradientDirection {
  LINEAR_UP
  LINEAR_DOWN
  RADIAL
}

enum PatternStyle {
  GRID
  MORPH
  ORGANIC
  MATRIX
}

enum ButtonStyle {
  SOLID
  GLASS
  OUTLINE
}

enum ButtonRadius {
  SQUARE
  ROUND
  ROUNDER
  FULL
}

enum ButtonShadow {
  NONE
  SOFT
  STRONG
  HARD
}
