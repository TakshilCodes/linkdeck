generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String             @id @default(uuid())
  email          String             @unique
  username       String?            @unique
  displayName    String?
  profileImgUrl  String?
  bio            String?
  hashedPassword String?
  authProvider   authProvider
  themeId        String?
  theme          DefaultTheme?      @relation(fields: [themeId], references: [id], onDelete: SetNull)
  customization  UserCustomization?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  links       Link[]
  collections Collection[]
  icons       SocialIcon[]
}

enum authProvider {
  GOOGLE
  GITHUB
  CREDENTIALS
}

model Link {
  id                String   @id @default(uuid())
  userId            String
  collectionId      String?
  name              String
  url               String
  isVisible         Boolean  @default(true)
  isLocked          Boolean  @default(false)
  lockToSubscribers Boolean  @default(false)
  isSensitive       Boolean  @default(false)
  clickCount        Int      @default(0)
  position          Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
}

model Collection {
  id        String   @id @default(uuid())
  userId    String
  name      String
  isVisible Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  links Link[]
}

model SocialIcon {
  id        String   @id @default(uuid())
  userId    String
  type      IconType
  url       String
  label     String?
  isVisible Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum IconType {
  INSTAGRAM
  X
  LINKEDIN
  FACEBOOK
  YOUTUBE
  GITHUB
  PERSONAL_WEBSITE
  PATREON
  KICK
  DISCORD
  PINTEREST
  TWITCH
  TELEGRAM
  THREADS
  SNAPCHAT
}

model DefaultTheme {
  id   String @id @default(uuid())
  name String
  slug String @unique

  wallpaperStyle    WallpaperStyle
  backgroundColor   String?
  gradientFrom      String?
  gradientTo        String?
  gradientDirection GradientDirection?
  patternStyle      PatternStyle?
  blurStrength      String?

  fontFamily String?

  buttonStyle     ButtonStyle
  buttonRadius    ButtonRadius
  buttonShadow    ButtonShadow
  buttonColor     String?
  buttonTextColor String?

  titleFontSize   String?
  titleColor      String?
  titleFontWeight String?

  profileFontSize String?
  profileColor    String?

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model UserCustomization {
  id     String @id @default(uuid())
  userId String @unique

  wallpaperStyle    WallpaperStyle?
  backgroundColor   String?
  gradientFrom      String?
  gradientTo        String?
  gradientDirection GradientDirection?
  patternStyle      PatternStyle?
  blurStrength      String?

  fontFamily String?

  buttonStyle     ButtonStyle?
  buttonRadius    ButtonRadius?
  buttonShadow    ButtonShadow?
  buttonColor     String?
  buttonTextColor String?

  titleFontSize   String?
  titleColor      String?
  titleFontWeight String?

  profileFontSize String?
  profileColor    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WallpaperStyle {
  FILL
  GRADIENT
  BLUR
  PATTERN
}

enum GradientDirection {
  LINEAR_UP
  LINEAR_DOWN
  RADIAL
}

enum PatternStyle {
  GRID
  MORPH
  ORGANIC
  MATRIX
}

enum ButtonStyle {
  SOLID
  GLASS
  OUTLINE
}

enum ButtonRadius {
  SQUARE
  ROUND
  ROUNDER
  FULL
}

enum ButtonShadow {
  NONE
  SOFT
  STRONG
  HARD
}
